  title   String
  message String
  type    NotificationType
  isRead  Boolean          @default(false)
  readAt  DateTime?

  // Optional deep-link e.g. { "feeId": "...", "route": "/fees" }
  meta Json?

  createdAt DateTime @default(now())

  @@index([schoolId, userId, isRead])
  @@index([schoolId, type])
  @@index([userId, createdAt])
}

