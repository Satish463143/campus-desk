// ============================================================
//  PAYMENT GATEWAY
// ============================================================

model SchoolPaymentGateway {
  id String @id @default(uuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  paymentMethod PaymentMethod
  status        UserStatus    @default(active)
  isDefault     Boolean       @default(false)

  /// ESEWA         → { merchantCode, secretKey, successUrl, failureUrl }
  /// KHALTI        → { publicKey, secretKey, returnUrl }
  /// FONEPAY       → { merchantId, secretKey, returnUrl }
  /// IMEPAY        → { merchantId, secretKey, module, returnUrl }
  /// BANK_TRANSFER → { bankName, accountName, accountNumber, qrImage }
  config Json

  payments FeePayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, paymentMethod])
  @@index([schoolId, status])
}

// ============================================================
//  AUDIT LOG  (unified — replaces FeeAuditLog)
//
//  Covers ALL modules: fee, attendance, LMS, admission, etc.
//  actorName and actorRole are snapshots — record stays meaningful
//  even after the actor is soft-deleted.
//
//  Query examples:
//    "Everything accountant X did today"
//      WHERE schoolId=? AND actorId=? AND DATE(createdAt)=today
//    "Who changed this fee record?"
//      WHERE entityType='StudentFee' AND entityId=?
//    "All payment failures this month"
//      WHERE action='PAYMENT_FAIL' AND createdAt >= monthStart
// ============================================================

model AuditLog {
  id       String @id @default(uuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  // Who — snapshots so record is valid even after soft delete
  actorId   String
  actorName String
  actorRole Role

  // What
  action     AuditAction
  entityType String // "StudentFee" | "Attendance" | "LMSExam" | ...
  entityId   String?
  studentId  String? // quick filter for student-related actions

  // Change tracking
  before Json? // state before action (null for CREATE)
  after  Json? // state after action  (null for DELETE)

  // Context
  meta      Json?
  ipAddress String?
  note      String?

  createdAt DateTime @default(now())

  @@index([schoolId, actorId])
  @@index([schoolId, entityType, entityId])
  @@index([schoolId, action])
  @@index([schoolId, studentId])
  @@index([schoolId, createdAt])
}

// ============================================================
//  NOTIFICATIONS
// ============================================================

model Notification {
  id       String @id @default(uuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

