  class   Class  @relation(fields: [classId], references: [id])

  sectionId String?
  section   Section? @relation(fields: [sectionId], references: [id])

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  chapterId String?
  chapter   LMSChapter? @relation(fields: [chapterId], references: [id])

  teacherId String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id])

  title        String
  description  String?
  instructions String?

  examCategory ExamType // formative | summative | terminal
  totalMarks   Float
  passMarks    Float?

  examDate DateTime? // date of this subject's exam
  startAt  DateTime? // exam hall start time
  endAt    DateTime? // exam hall end time

  questionText            String?
  questionFileKeys        String[]
  externalQuestionFileUrl String?

  status          ExamStatus @default(draft)
  isPublished     Boolean    @default(false)
  resultPublished Boolean    @default(false)

  submissions LMSExamSubmission[]

