// ============================================================
//  GRADE SCALE
//  Each school defines their own grading system.
//  Backend uses this to: percentage → letter grade → GPA
//  for mark sheet & grade card PDF generation.
//
//  Example (NEB Nepal):
//    A+  90–100  4.0  Outstanding
//    A   80–89   3.6  Excellent
//    B+  70–79   3.2  Very Good
//    B   60–69   2.8  Good
//    C+  50–59   2.4  Satisfactory
//    C   40–49   2.0  Acceptable
//    D   35–39   1.6  Partially Acceptable
//    NG   0–34   0.0  Not Graded
// ============================================================

model GradeScale {
  id       String @id @default(uuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  label      String // "A+", "A", "B+", "B", "C+", "C", "D", "NG"
  minPercent Decimal @db.Decimal(5, 2) // 90.00
  maxPercent Decimal @db.Decimal(5, 2) // 100.00
  gradePoint Decimal @db.Decimal(3, 2) // 4.0, 3.6, 3.2 ...
  remarks    String? // "Outstanding", "Excellent", "Very Good" ...
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, label])
  @@index([schoolId])
  @@index([schoolId, minPercent, maxPercent])
}
