// ============================================================
//  School ERP — Prisma Schema (Production-Ready v1.0)
//

// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), pgcrypto, citext]
}

// ============================================================
//  ENUMS
// ============================================================

enum SchoolStatus {
  new_registration
  active
  inactive
  closure_requested
  closed
  suspended
}

enum SchoolType {
  private
  public
}

enum EducationLevel {
  primary
  secondary
  higher_secondary
  university
  college
}

enum Role {
  super_admin
  principal
  admin_staff
  accountant
  teacher
  student
  parent
}

enum UserStatus {
  active
  inactive
}

enum Gender {
  male
  female
  other
}

enum AcademicStatus {
  admitted
  pending
  graduated
  dropped
  transferred
  migration
}

enum RelationType {
  mother
  father
  guardian
}

enum DayOfWeek {
  sunday
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
}

enum AttendanceStatus {
  present
  absent
  leave
  late
}

enum FeeFrequency {
  monthly
  quarterly
  half_yearly
  yearly
  one_time
}

enum FeeStatus {
  pending
  partial
  paid
  overdue
  partial_overdue
  waived
}

enum FeeCategoryScope {
  school
  class
  optional
}

// compulsory → auto-assigned when student is enrolled in a class
// optional   → manually assigned per student by accountant
enum FeeAssignmentType {
  compulsory
  optional
}

enum PaymentMethod {
  cash
  fone_pay
  check
  bank_transfer
  esewa
  khalti
  ime_pay
  card
}

enum PaymentStatus {
  initiated
  pending
  success
  failed
  cancelled
  expired
  requires_verification
}

enum ReminderType {
  first_notice
  second_notice
  final_notice
}

enum DiscountType {
  fixed
  percentage
}

enum ClassMode {
  offline
  online
}

enum LMSPublishStatus {
  draft
  published
  archived
}

enum LMSResourceType {
  video
  pdf
  note
  attachment
  link
}

enum AssignmentSubmissionType {
  text
  file
  text_file
  link
}

enum AssignmentStatus {
  draft
  published
  closed
  archived
}

enum SubmissionStatus {
  submitted
  resubmitted
  reviewed
  graded
  late
}

enum LiveClassStatus {
  scheduled
  live
  completed
  cancelled
}

enum LiveClassType {
  regular
  extra
}

enum ExamStatus {
  draft
  published
  closed
  evaluated
  archived
}

// Single enum — ExamCategory was a duplicate, removed
enum ExamType {
  formative
  summative
  terminal
}

enum ExamSubmissionStatus {
  pending
  submitted
  late
  reviewed
}

enum DiscussionTargetType {
  chapter
  assignment
  live_class
  exam
  general
}

enum PublicAdmissionStatus {
  pending
  approved
  rejected
}

enum NotificationType {
  fee_reminder
  fee_paid
  attendance
  assignment
  exam
  announcement
  admission
  general
}

enum InvoiceStatus {
  PENDING_REVIEW
  APPROVED
  SENT
  PAID
  EXPIRED
}

enum InvoiceType {
  FEE_INVOICE
  PAYMENT_RECEIPT
  OUTSTANDING
  BULK
  PARTIAL_PAYMENT
}

// Unified audit actions — covers all modules
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  PUBLISH
  ARCHIVE
  PAYMENT_INITIATE
  PAYMENT_SUCCESS
  PAYMENT_FAIL
  FEE_ASSIGN
  FEE_WAIVE
  ENROLLMENT
}

// ============================================================
//  SCHOOL
// ============================================================

model School {
  id String @id @default(uuid())

  schoolName String
  schoolCode String? @unique

  schoolType     SchoolType     @default(private)
  educationLevel EducationLevel @default(primary)

  schoolEmail    String? @unique
  schoolPhone    String?
  alternatePhone String?
  schoolWebsite  String?

  schoolStatus SchoolStatus @default(new_registration)

  establishedYear    Int?
  panNumber          String? @unique
  registrationNumber String? @unique

  /// { "country": "Nepal", "province": "...", "district": "...", "fullAddress": "..." }
  address Json

  logo       String?
  coverImage String?

  /// { "motto": "...", "description": "..." }
  branding Json?

  isProfileCompleted Boolean   @default(false)
  closedAt           DateTime?

  // ── Relations ──────────────────────────────────────────────
  users                    User[]
  studentProfiles          StudentProfile[]
  parentProfiles           ParentProfile[]
  teacherProfiles          TeacherProfile[]
  academicYears            AcademicYear[]
  classes                  Class[]
  sections                 Section[]
  subjects                 Subject[]
  classSubjects            ClassSubject[]
  sectionSubjectTeachers   SectionSubjectTeacher[]
  periods                  Period[]
  timetables               Timetable[]
  studentAttendances       StudentAttendance[]
  teacherAttendances       TeacherAttendance[]
  feeCategories            FeeCategory[]
  feeStructures            FeeStructure[]
  studentFees              StudentFee[]
  studentFeeAutoLogs       StudentFeeAutoLog[]
  studentScholarships      StudentScholarship[]
  feePayments              FeePayment[]
  feePaymentAllocations    FeePaymentAllocation[]
  feeSetting               FeeSetting?
  feeReminders             FeeReminder[]
  invoices                 Invoice[]
  invoiceFees              InvoiceFee[]
  schoolPaymentGateways    SchoolPaymentGateway[]
  lmsSyllabuses            LMSSyllabus[]
  lmsChapters              LMSChapter[]
  lmsResources             LMSResource[]
  lmsAssignments           LMSAssignment[]
  lmsAssignmentSubmissions LMSAssignmentSubmission[]
  lmsLiveClasses           LMSLiveClass[]
  lmsChapterProgresses     LMSChapterProgress[]
  lmsResourceProgresses    LMSResourceProgress[]
  lmsAnnouncements         LMSAnnouncement[]
  lmsDiscussions           LMSDiscussion[]
  lmsExams                 LMSExam[]
  lmsExamSubmissions       LMSExamSubmission[]
  progressReports          ProgressReport[]
  gradeScales              GradeScale[]
  notifications            Notification[]
  auditLogs                AuditLog[]
  publicAdmissions         PublicAdmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
//  USER
// ============================================================

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  password     String
  phone        String?
  role         Role
  status       UserStatus @default(inactive)
  profileImage String?
  lastLoginAt  DateTime?

  /// { "country": "Nepal", "province": "...", "district": "...", "fullAddress": "..." }
  address Json

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id])

  studentProfile           StudentProfile?
  parentProfile            ParentProfile?
  teacherProfile           TeacherProfile?
  notifications            Notification[]
  reviewedPublicAdmissions PublicAdmission[] @relation("PublicAdmissionReviewer")

  // Soft delete — null = active, set = deleted
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([role])
  @@index([deletedAt])
}

// ============================================================
//  STUDENT
// ============================================================

model StudentProfile {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  admissionNumber String?
  rollNumber      String?

  dateOfBirth DateTime?
  gender      Gender?
  bloodGroup  String?

  academicStatus AcademicStatus @default(admitted)

  // Personal & family info
  dateOfAdmission   DateTime?
  studentInfo       Json?
  father            Json?
  mother            Json?
  guardian          Json?
  familyInfo        Json?
  background        Json?
  fees              Json?
  declarationSigned Boolean   @default(false)

  // Soft delete
  deletedAt DateTime?

  // ── Relations ──────────────────────────────────────────────
  parents                  ParentProfile[]           @relation("StudentToParent")
  enrollments              StudentEnrollment[]
  studentAttendances       StudentAttendance[]
  studentFees              StudentFee[]
  studentFeeAutoLogs       StudentFeeAutoLog[]
  scholarships             StudentScholarship[]
  feePayments              FeePayment[]
  invoices                 Invoice[]
  lmsAssignmentSubmissions LMSAssignmentSubmission[]
  lmsChapterProgresses     LMSChapterProgress[]
  lmsResourceProgresses    LMSResourceProgress[]
  lmsExamSubmissions       LMSExamSubmission[]
  progressReports          ProgressReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([admissionNumber])
  @@index([deletedAt])
}

// Source of truth for which class & section a student is in per academic year
model StudentEnrollment {
  id String @id @default(uuid())

  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id])

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  sectionId String
  section   Section @relation(fields: [sectionId], references: [id])

  rollNumber String?

  createdAt DateTime @default(now())

  @@unique([studentId, academicYearId])
  @@index([academicYearId])
  @@index([classId])
  @@index([sectionId])
}

// ============================================================
//  PARENT
// ============================================================

model ParentProfile {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  occupation       String?
  relationType     RelationType?
  emergencyContact String?

  students     StudentProfile[] @relation("StudentToParent")
  feeReminders FeeReminder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
}

// ============================================================
//  TEACHER
// ============================================================

model TeacherProfile {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  employeeId      String?
  qualification   String?
  experienceYears Int?
  joiningDate     DateTime?
  salary          Decimal?  @db.Decimal(12, 2)
  department      String?
  designation     String?

  // Soft delete
  deletedAt DateTime?

  // ── Relations ──────────────────────────────────────────────
  classTeacherSections   Section[]               @relation("ClassTeacher")
  sectionSubjectTeachers SectionSubjectTeacher[]
  timetables             Timetable[]
  studentAttendances     StudentAttendance[]
  teacherAttendances     TeacherAttendance[]
  lmsAssignments         LMSAssignment[]
  lmsLiveClasses         LMSLiveClass[]
  lmsExams               LMSExam[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, employeeId])
  @@index([schoolId])
  @@index([deletedAt])
}

// ============================================================
//  ACADEMIC STRUCTURE
// ============================================================

model AcademicYear {
  id String @id @default(uuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  name      String // "2024-2025"
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)

  classes            Class[]
  sections           Section[]
  studentEnrollments StudentEnrollment[]
  periods            Period[]
  timetables         Timetable[]
  studentAttendances StudentAttendance[]
  feeStructures      FeeStructure[]
  studentFees        StudentFee[]
  lmsSyllabuses      LMSSyllabus[]
  lmsChapters        LMSChapter[]
  lmsAssignments     LMSAssignment[]
  lmsLiveClasses     LMSLiveClass[]
  lmsAnnouncements   LMSAnnouncement[]
  lmsDiscussions     LMSDiscussion[]
  lmsExams           LMSExam[]
  progressReports    ProgressReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Class {
  id String @id @default(uuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  name         String // "Grade 1", "Grade 10"
  numericLevel Int // 1, 2, 3 ... for sorting & promotion logic

  sections           Section[]
  classSubjects      ClassSubject[]
  studentEnrollments StudentEnrollment[]
  timetables         Timetable[]
  studentAttendances StudentAttendance[]
  feeStructures      FeeStructure[]
  lmsSyllabuses      LMSSyllabus[]
  lmsChapters        LMSChapter[]
  lmsAssignments     LMSAssignment[]
  lmsLiveClasses     LMSLiveClass[]
  lmsAnnouncements   LMSAnnouncement[]
  lmsDiscussions     LMSDiscussion[]
  lmsExams           LMSExam[]
  progressReports    ProgressReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, academicYearId, name])
  @@index([schoolId])
  @@index([academicYearId])
}

model Section {
  id String @id @default(uuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  name     String // "A", "B", "C"
  capacity Int?

  classTeacherId String?
  classTeacher   TeacherProfile? @relation("ClassTeacher", fields: [classTeacherId], references: [id])

  subjectTeachers    SectionSubjectTeacher[]
  studentEnrollments StudentEnrollment[]
  timetables         Timetable[]
  studentAttendances StudentAttendance[]
  lmsSyllabuses      LMSSyllabus[]
  lmsChapters        LMSChapter[]
  lmsAssignments     LMSAssignment[]
  lmsLiveClasses     LMSLiveClass[]
  lmsAnnouncements   LMSAnnouncement[]
  lmsDiscussions     LMSDiscussion[]
  lmsExams           LMSExam[]
  progressReports    ProgressReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([classId, name])
  @@index([schoolId])
  @@index([academicYearId])
  @@index([classId])
}

model Subject {
  id String @id @default(uuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  name String // "Mathematics"
  code String? // "MATH101"

  classSubjects      ClassSubject[]
  sectionTeachers    SectionSubjectTeacher[]
  timetables         Timetable[]
  studentAttendances StudentAttendance[]
  lmsSyllabuses      LMSSyllabus[]
  lmsChapters        LMSChapter[]
  lmsAssignments     LMSAssignment[]
  lmsLiveClasses     LMSLiveClass[]
  lmsAnnouncements   LMSAnnouncement[]
  lmsDiscussions     LMSDiscussion[]
  lmsExams           LMSExam[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
}

model ClassSubject {
  id String @id @default(uuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@unique([classId, subjectId])
  @@index([schoolId])
}

model SectionSubjectTeacher {
  id String @id @default(uuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  sectionId String
  section   Section @relation(fields: [sectionId], references: [id])

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  teacherId String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id])

  isPrimary Boolean @default(true)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sectionId, subjectId, teacherId])
  @@index([schoolId])
  @@index([sectionId])
  @@index([teacherId])
}

// startTime / endTime as "HH:MM" strings — avoids timezone issues
model Period {
  id String @id @default(uuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  name         String // "Period 1", "Break", "Lunch"
  periodNumber Int
  startTime    String // "08:00"
  endTime      String // "09:00"

  isBreak  Boolean @default(false)
  isActive Boolean @default(true)

  timetableEntries   Timetable[]
  studentAttendances StudentAttendance[]
  lmsLiveClasses     LMSLiveClass[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, academicYearId, periodNumber])
  @@index([schoolId, academicYearId])
  @@index([schoolId, isActive])
}

model Timetable {
  id String @id @default(uuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  sectionId String
  section   Section @relation(fields: [sectionId], references: [id])

  periodId String
  period   Period @relation(fields: [periodId], references: [id])

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  teacherId String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id])

  dayOfWeek  DayOfWeek
  classMode  ClassMode @default(offline)
  roomNumber String?
  isActive   Boolean   @default(true)

  studentAttendances StudentAttendance[]
  liveClasses        LMSLiveClass[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sectionId, dayOfWeek, periodId])
  @@index([schoolId, academicYearId])
  @@index([classId, sectionId])
  @@index([sectionId, dayOfWeek])
  @@index([teacherId, dayOfWeek, periodId])
  @@index([subjectId])
}

// ============================================================
//  ATTENDANCE
// ============================================================

model StudentAttendance {
  id String @id @default(uuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  sectionId String
  section   Section @relation(fields: [sectionId], references: [id])

  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id])

  teacherId String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id])

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  periodId String
  period   Period @relation(fields: [periodId], references: [id])

  timetableId String
  timetable   Timetable @relation(fields: [timetableId], references: [id])

  date   DateTime // normalized to 00:00:00.000Z
  status AttendanceStatus
  remark String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date, periodId])
  @@index([schoolId, sectionId, date, periodId])
  @@index([schoolId, studentId, date])
  @@index([schoolId, teacherId, date, periodId])
  @@index([schoolId, date])
}

model TeacherAttendance {
  id String @id @default(uuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  teacherId String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id])

  date         DateTime
  status       AttendanceStatus
  checkInTime  DateTime?
  checkOutTime DateTime?
  remark       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teacherId, date])
  @@index([schoolId])
  @@index([teacherId, date])
}

// ============================================================
//  FEE MANAGEMENT
// ============================================================

model FeeCategory {
  id       String @id @default(uuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  name        String
  code        String?
  scope       FeeCategoryScope @default(school)
  description String?

  feeStructures FeeStructure[]
  scholarships  StudentScholarship[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@unique([schoolId, code])
  @@index([schoolId])
}

// assignmentType:
//   compulsory → system auto-creates StudentFee on enrollment
//   optional   → accountant manually assigns per student
model FeeStructure {
  id       String @id @default(uuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  classId String
  class   Class  @relation(fields: [classId], references: [id])

  feeCategoryId String
  feeCategory   FeeCategory @relation(fields: [feeCategoryId], references: [id])

  amount              Decimal           @db.Decimal(12, 2)
  frequency           FeeFrequency
  assignmentType      FeeAssignmentType @default(compulsory)
  allowPartialPayment Boolean           @default(true)
  isActive            Boolean           @default(true)

  studentFees        StudentFee[]
  studentFeeAutoLogs StudentFeeAutoLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, classId, academicYearId])
  @@index([schoolId, assignmentType])
  @@index([feeCategoryId])
}

// Audit trail for every auto-assignment event
model StudentFeeAutoLog {
  id String @id @default(uuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id])

  feeStructureId String
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id])

  studentFeeId String     @unique
  studentFee   StudentFee @relation(fields: [studentFeeId], references: [id])

  // "system_enrollment" = auto | userId = manual override by staff
  triggeredBy String
  note        String?

  createdAt DateTime @default(now())

  @@index([schoolId, studentId])
  @@index([feeStructureId])
}

model StudentFee {
  id String @id @default(uuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id])

  feeStructureId String
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id])

  // Snapshot of assignmentType at time of assignment
  assignmentType FeeAssignmentType @default(compulsory)
  // null = auto by system | userId = manually assigned by accountant
  assignedById   String?

  periodLabel String?
  periodStart DateTime?
  periodEnd   DateTime?

  originalAmount Decimal @db.Decimal(12, 2)
  discountAmount Decimal @default(0) @db.Decimal(12, 2)
  netAmount      Decimal @db.Decimal(12, 2)
  paidAmount     Decimal @default(0) @db.Decimal(12, 2)
  balanceAmount  Decimal @db.Decimal(12, 2)

  dueDate       DateTime
  status        FeeStatus @default(pending)
  reminderDate  DateTime?
  reminderCount Int       @default(0)

  paymentAllocations FeePaymentAllocation[]
  reminders          FeeReminder[]
  autoLog            StudentFeeAutoLog?
  invoiceFees        InvoiceFee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, feeStructureId, dueDate])
  @@index([schoolId, studentId, dueDate])
  @@index([schoolId, status, dueDate])
  @@index([schoolId, reminderDate])
  @@index([assignmentType])
}

model StudentScholarship {
  id String @id @default(uuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id])

  feeCategoryId String?
  feeCategory   FeeCategory? @relation(fields: [feeCategoryId], references: [id])

  type       DiscountType
  value      Decimal      @db.Decimal(12, 2)
  reason     String?
  referredBy String?

  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, feeCategoryId, startDate, endDate, type])
  @@index([schoolId, studentId, startDate, endDate])
  @@index([feeCategoryId])
}

model FeePayment {
  id String @id @default(uuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id])

  gatewayId String?
  gateway   SchoolPaymentGateway? @relation(fields: [gatewayId], references: [id])

  totalAmount   Decimal       @db.Decimal(12, 2)
  paymentDate   DateTime?
  paymentMethod PaymentMethod
  status        PaymentStatus @default(initiated)

  paymentReference String  @unique
  invoiceReference String?

  transactionId    String?
  gatewayReference String?
  gatewayToken     String?

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  // For manual / bank transfer
  receiptUrl  String?
  depositedBy String?
  verifiedBy  String?
  verifiedAt  DateTime?

  note       String?
  receivedBy String?

  // Prevents duplicate charges on network retries
  idempotencyKey String? @unique

  allocations FeePaymentAllocation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, studentId, paymentDate])
  @@index([schoolId, paymentMethod, status])
  @@index([schoolId, createdAt])
  @@index([transactionId])
  @@index([gatewayReference])
}

